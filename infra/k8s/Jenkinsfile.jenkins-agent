// Jenkins Agent K8s 資源初始化
// 用途：初次建叢集、或需要重建 jenkins-agents namespace 時跑
pipeline {
    agent any

    environment {
        CLUSTER_NAME = "main-eks"
        AWS_REGION   = "ap-northeast-1"
        SSM_PREFIX   = "/eks/main-eks"
    }

    stages {
        stage('Configure kubectl') {
            steps {
                sh "aws eks update-kubeconfig --name ${CLUSTER_NAME} --region ${AWS_REGION}"
            }
        }

        stage('Read SSM Parameters') {
            steps {
                script {
                    env.AGENT_ROLE_ARN = sh(
                        script: "aws ssm get-parameter --name ${SSM_PREFIX}/jenkins-agent-role-arn --region ${AWS_REGION} --query Parameter.Value --output text",
                        returnStdout: true
                    ).trim()
                }
            }
        }

        stage('Apply Namespace and RBAC') {
            steps {
                sh "kubectl apply -f infra/k8s/jenkins-agent-namespace.yaml"
                sh "kubectl apply -f infra/k8s/jenkins-agent-rbac.yaml"
            }
        }

        stage('Annotate ServiceAccount with IRSA') {
            steps {
                sh """
                    kubectl annotate sa jenkins-agent \
                        -n jenkins-agents \
                        eks.amazonaws.com/role-arn=${env.AGENT_ROLE_ARN} \
                        --overwrite
                """
            }
        }

        stage('Verify') {
            steps {
                sh "kubectl get sa jenkins-agent -n jenkins-agents -o yaml | grep role-arn"
                sh "kubectl get clusterrolebinding jenkins-agent-deploy"
            }
        }
    }
}
